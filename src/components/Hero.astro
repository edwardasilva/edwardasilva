---
/**
 * src/components/Hero.astro
 * Hero Section Component
 *
 * Author: Edward Silva
 * Creation Date: 16 March, 2026
 * Last Update: 14 April, 2026
 *
 * Renders the main hero section with profile introduction, social links,
 * and call-to-action buttons for the portfolio landing page.
 *
 * File Structure:
 * - Social Links Configuration: Contact and follow links
 * - Template: Hero layout with typography and buttons
 *
 * Used in: src/pages/index.astro
 *
 * Licence/Copyright: Licensed under MIT License
 */

// Hero section - the big intro at the top
import { getExpectedGraduation, getResumePdfUrl, resume } from '../data/resume';

const education = resume.education?.[0];
---

<section
  class="min-h-[85vh] sm:min-h-[80vh] flex items-center justify-center pt-20 pb-16 border-b border-[#dfd3b8] relative overflow-hidden"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full relative z-10">
    <!-- Status badge -->
    {
      getExpectedGraduation() && (
        <div
          class="flex flex-wrap items-center gap-3 mb-6 animate-fade-in-up"
          style="animation-delay: 0ms;"
        >
          <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium bg-[#f4e7cb]/80 text-[#5f6578] border border-[#dfd3b8]">
            Graduating {getExpectedGraduation()}
          </span>
        </div>
      )
    }

    <!-- Name -->
    <h1
      class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-semibold font-serif mb-4 sm:mb-6 tracking-tight text-[#292b31] leading-[1.1] animate-fade-in-up"
      style="animation-delay: 100ms;"
    >
      {resume.personal.name}
    </h1>

    <!-- Education subtitle -->
    {
      education && (
        <p
          class="text-base sm:text-lg text-[#6f7588] mb-4 font-medium animate-fade-in-up"
          style="animation-delay: 150ms;"
        >
          {education.degree} @ {education.institution}
        </p>
      )
    }

    <!-- Profile summary -->
    <p
      class="text-lg sm:text-xl md:text-2xl text-[#5f6578] max-w-2xl leading-relaxed mb-8 sm:mb-10 animate-fade-in-up"
      style="animation-delay: 200ms;"
    >
      {resume.profile.text}
    </p>

    <!-- CTA Buttons -->
    <div
      class="flex flex-col sm:flex-row gap-3 sm:gap-4 animate-fade-in-up"
      style="animation-delay: 300ms;"
    >
      <a
        href="#experience"
        class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl bg-[#292b31] text-white text-sm font-semibold hover:bg-[#343842] transition-all shadow-sm hover:shadow-md active:scale-[0.98]"
      >
        View Experience
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="M12 5v14"></path><path d="m19 12-7 7-7-7"></path></svg
        >
      </a>
      <a
        href={getResumePdfUrl()}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl bg-white/90 text-[#292b31] border border-[#dfd3b8] text-sm font-semibold hover:bg-white transition-all shadow-sm hover:shadow-md active:scale-[0.98]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline
            points="7 10 12 15 17 10"></polyline><line x1="12" x2="12" y1="15" y2="3"></line></svg
        >
        Download Resume
      </a>
    </div>

    <!-- Quick contact links -->
    <div
      class="flex flex-wrap items-center gap-4 sm:gap-6 mt-10 sm:mt-12 pt-8 sm:pt-10 border-t border-[#dfd3b8] animate-fade-in-up"
      style="animation-delay: 400ms;"
    >
      <a
        href={resume.personal.github}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-sm text-[#6f7588] hover:text-[#292b31] transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
          ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
        >
        GitHub
      </a>
      <a
        href={resume.personal.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-sm text-[#6f7588] hover:text-[#292b31] transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"
          ></circle></svg
        >
        LinkedIn
      </a>
      <a
        href={`mailto:${resume.personal.email}`}
        class="flex items-center gap-2 text-sm text-[#6f7588] hover:text-[#292b31] transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
            d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
        >
        {resume.personal.email}
      </a>
    </div>
  </div>
</section>
