---
// Reusable section wrapper with the side title layout
interface Props {
  id?: string;
  title: string;
  class?: string;
}

const { id, title, class: className } = Astro.props;
---

<section id={id} class:list={["py-16 sm:py-20 lg:py-24 border-b border-[#dfd3b8] last:border-0", className]}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 xl:gap-16">
      <!-- Section Title -->
      <div class="lg:w-1/4 shrink-0">
        <h2 class="text-xl sm:text-2xl font-semibold font-serif text-[#292b31] lg:sticky lg:top-24 tracking-tight">
          <span class="text-amber-500 mr-2 opacity-80">•</span>
          <span class="marker-underline">{title}</span>
        </h2>
      </div>
      <!-- Section Content -->
      <div class="lg:w-3/4 min-w-0">
        <slot />
      </div>
    </div>
  </div>
</section>
