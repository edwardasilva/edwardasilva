---
// Work experience timeline - only shows the good stuff (experienceType = 'All')
import Section from './Section.astro';
import { resume } from '../data/resume';

const experience = resume.experiences.filter(exp => exp.experienceType === 'All');

function isIncoming(duration: string): boolean {
    return duration.toLowerCase() === 'incoming' || duration.toLowerCase().includes('starting');
}
---

<Section id="experience" title="Experience">
    <div class="relative border-l-2 border-slate-200/80 dark:border-slate-800/80 ml-2 sm:ml-3 space-y-10 sm:space-y-12">
        {experience.map((job) => {
            const incoming = isIncoming(job.duration);
            return (
                <article class="relative pl-6 sm:pl-8 md:pl-10 group">
                    <!-- Timeline Dot -->
                    <div class:list={[
                        "absolute -left-[7px] top-1.5 h-3 w-3 rounded-full border-[3px] border-[#fbf7f0] dark:border-slate-950 shadow-sm group-hover:scale-110 transition-transform",
                        incoming ? "bg-emerald-400 dark:bg-emerald-500" : "bg-amber-400 dark:bg-amber-500"
                    ]}></div>

                    <!-- Header -->
                    <div class="flex flex-col gap-2 mb-3">
                        <div class="flex flex-wrap items-center gap-2">
                            <h3 class="text-lg sm:text-xl font-semibold font-serif text-slate-900 dark:text-slate-100 leading-snug">
                                {job.title}
                            </h3>
                            {incoming && (
                                <span class="inline-flex items-center gap-1 text-[10px] font-semibold px-2 py-0.5 rounded-full bg-emerald-50 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300 border border-emerald-200/80 dark:border-emerald-700/50">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                                    Incoming
                                </span>
                            )}
                        </div>

                        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm">
                            <span class="font-medium text-slate-700 dark:text-slate-200">{job.company}</span>
                            {job.location && (
                                <>
                                    <span class="text-slate-300 dark:text-slate-600 hidden sm:inline">•</span>
                                    <span class="text-slate-500 dark:text-slate-400">{job.location}</span>
                                </>
                            )}
                            {!incoming && (
                                <>
                                    <span class="text-slate-300 dark:text-slate-600 hidden sm:inline">•</span>
                                    <span class="text-slate-500 dark:text-slate-400 text-xs sm:text-sm">{job.duration}</span>
                                </>
                            )}
                        </div>
                    </div>

                    <!-- Description -->
                    {job.description.length > 0 && (
                        incoming ? (
                            <p class="text-slate-600 dark:text-slate-400 text-sm sm:text-base">
                                {job.description.join(' · ')}
                            </p>
                        ) : (
                            <ul class="space-y-2 mt-4">
                                {job.description.map((desc) => (
                                    <li class="flex items-start gap-3">
                                        <span class="mt-2 w-1.5 h-1.5 rounded-full bg-slate-300 dark:bg-slate-600 shrink-0"></span>
                                        <span class="text-slate-600 dark:text-slate-300 leading-relaxed text-sm sm:text-base">{desc}</span>
                                    </li>
                                ))}
                            </ul>
                        )
                    )}
                </article>
            );
        })}
    </div>
</Section>
