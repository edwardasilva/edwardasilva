---
/**
 * src/components/Coursework.astro
 * Coursework Component
 *
 * Author: Edward Silva
 * Creation Date: 16 March, 2026
 * Last Update: 14 April, 2026
 *
 * Displays coursework organized by category (Electrical Engineering, Computer Science)
 * with filterable tabs and expandable course descriptions.
 *
 * File Structure:
 * - Tab Configuration: Category setup with UI properties
 * - Course Filtering: Functions to filter and sort courses by level
 * - Template: Tab navigation with course listings
 *
 * Used in: src/pages/coursework.astro
 *
 * Licence/Copyright: Licensed under MIT License
 */

// Coursework tabs - EE and CS courses with expandable descriptions
import Section from './Section.astro';
import { resume } from '../data/resume';
import type { Course } from '../data/types';

type SubjectKey = 'Electrical Engineering' | 'Computer Science';

const coursesByCategory = resume.educationSupplementary?.courses ?? {};
const ALLOWED_CATEGORIES = new Set(['Computer Science', 'Electrical Engineering']);
const ALLOWED_CODE_PREFIXES = ['CSCI', 'EENG'];

function parseCourseNumber(code: string): number | undefined {
  const match = code.match(/\b(\d{3,4})\b/);
  if (!match) return undefined;
  return Number(match[1]);
}

// Filter out intro courses (< 300 level) and sort by course number descending
function getFilteredCourses(category: string): Course[] {
  const courses = coursesByCategory[category] ?? [];
  return courses
    .filter((c) => {
      if (c.experienceType !== 'All' && c.experienceType !== 'Site') return false;
      if (String(c.relevancy ?? '').toLowerCase() !== 'yes') return false;
      const code = (c.code ?? '').trim();
      const num = parseCourseNumber(code);
      if (num !== undefined && num < 300) return false;
      return ALLOWED_CODE_PREFIXES.some((p) => code.startsWith(`${p} `));
    })
    .sort((a, b) => {
      const numA = parseCourseNumber(a.code ?? '') ?? 0;
      const numB = parseCourseNumber(b.code ?? '') ?? 0;
      return numB - numA; // Descending order (higher levels first)
    });
}

const eeCourses = getFilteredCourses('Electrical Engineering');
const csCourses = getFilteredCourses('Computer Science');

const tabs: Array<{
  id: string;
  label: string;
  shortLabel: string;
  courses: Course[];
  accentColor: string;
  pillClass: string;
}> = [
  {
    id: 'ee',
    label: 'Electrical Engineering',
    shortLabel: 'EE',
    courses: eeCourses,
    accentColor: 'amber',
    pillClass: 'bg-[#f2e2c4]/85 text-[#6f84bb]',
  },
  {
    id: 'cs',
    label: 'Computer Science',
    shortLabel: 'CS',
    courses: csCourses,
    accentColor: 'sky',
    pillClass: 'bg-[#e8edf8] text-[#6f84bb]',
  },
];

const totalCourses = eeCourses.length + csCourses.length;
---

<Section id="classes" title="Classes">
  {
    totalCourses === 0 ? (
      <p class="text-sm text-[#5f6578]">Coursework will appear here once courses are added.</p>
    ) : (
      <div class="space-y-6">
        <div class="border-b border-[#dfd3b8]" role="tablist">
          {tabs.map((tab, index) => (
            <button
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              aria-controls={`panel-${tab.id}`}
              id={`tab-${tab.id}`}
              data-tab={tab.id}
              class:list={[
                'tab-btn relative px-4 py-3 text-sm font-medium transition-colors',
                'text-[#6f7588] hover:text-[#292b31]',
                'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#8ea2d8] focus-visible:ring-offset-2',
                index === 0 && 'text-[#292b31]',
              ]}
            >
              <span class="hidden sm:inline">{tab.label}</span>
              <span class="sm:hidden">{tab.shortLabel}</span>
              <span class="ml-2 text-xs px-1.5 py-0.5 rounded-full bg-[#f4e7cb] text-[#6f7588]">
                {tab.courses.length}
              </span>
              <span
                class:list={[
                  'tab-indicator absolute bottom-0 left-0 right-0 h-0.5 rounded-full transition-opacity',
                  tab.accentColor === 'amber' ? 'bg-[#8ea2d8]' : 'bg-[#8ea2d8]',
                  index === 0 ? 'opacity-100' : 'opacity-0',
                ]}
              />
            </button>
          ))}
        </div>

        {tabs.map((tab, index) => (
          <div
            role="tabpanel"
            id={`panel-${tab.id}`}
            aria-labelledby={`tab-${tab.id}`}
            data-panel={tab.id}
            class:list={['tab-panel', index !== 0 && 'hidden']}
          >
            {tab.courses.length === 0 ? (
              <p class="text-sm text-[#6f7588] py-4">No courses to display.</p>
            ) : (
              <div class="grid gap-2">
                {tab.courses.map((course) => (
                  <details class="group rounded-lg bg-white/60 border border-[#dfd3b8] hover:border-[#d8ccb0]/80 transition-all">
                    <summary class="flex items-center gap-3 sm:gap-4 p-3 sm:p-4 cursor-pointer select-none list-none">
                      <span
                        class:list={[
                          'shrink-0 text-[11px] sm:text-xs font-mono font-medium px-2 py-1 rounded',
                          tab.pillClass,
                        ]}
                      >
                        {course.code}
                      </span>

                      <span class="flex-1 min-w-0 text-sm sm:text-base font-medium text-[#292b31] leading-snug">
                        {course.name}
                        {course.alias && (
                          <span class="text-[#81889c] font-normal text-xs ml-2">
                            ({course.alias})
                          </span>
                        )}
                      </span>

                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="shrink-0 text-[#81889c] group-open:rotate-180 transition-transform duration-200"
                      >
                        <polyline points="6 9 12 15 18 9" />
                      </svg>
                    </summary>

                    <div class="px-3 sm:px-4 pb-3 sm:pb-4 pt-0">
                      <p class="text-sm text-[#5f6578] leading-relaxed pl-[calc(theme(spacing.2)+theme(spacing.3))] sm:pl-[calc(theme(spacing.2)+theme(spacing.4)+theme(spacing.8))]">
                        {course.description}
                      </p>
                    </div>
                  </details>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    )
  }
</Section>

<script>
  // Tab switching (works as accordion without JS)
  document.addEventListener('DOMContentLoaded', () => {
    const tabButtons = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
    const tabPanels = document.querySelectorAll<HTMLDivElement>('.tab-panel');

    tabButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetId = btn.dataset.tab;
        if (!targetId) return;

        // Update buttons
        tabButtons.forEach((b) => {
          const isActive = b.dataset.tab === targetId;
          b.setAttribute('aria-selected', isActive ? 'true' : 'false');
          b.classList.toggle('text-[#292b31]', isActive);
          b.classList.toggle('text-[#6f7588]', !isActive);

          const indicator = b.querySelector('.tab-indicator');
          if (indicator) {
            indicator.classList.toggle('opacity-100', isActive);
            indicator.classList.toggle('opacity-0', !isActive);
          }
        });

        // Update panels
        tabPanels.forEach((panel) => {
          const isActive = panel.dataset.panel === targetId;
          panel.classList.toggle('hidden', !isActive);
        });
      });
    });

    // Keyboard navigation
    const tabList = document.querySelector('[role="tablist"]');
    tabList?.addEventListener('keydown', (e) => {
      const event = e as KeyboardEvent;
      if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(event.key)) return;

      const tabs = Array.from(tabButtons);
      const currentIndex = tabs.findIndex((t) => t.getAttribute('aria-selected') === 'true');
      let newIndex = currentIndex;

      switch (event.key) {
        case 'ArrowLeft':
          newIndex = currentIndex > 0 ? currentIndex - 1 : tabs.length - 1;
          break;
        case 'ArrowRight':
          newIndex = currentIndex < tabs.length - 1 ? currentIndex + 1 : 0;
          break;
        case 'Home':
          newIndex = 0;
          break;
        case 'End':
          newIndex = tabs.length - 1;
          break;
      }

      tabs[newIndex]?.focus();
      tabs[newIndex]?.click();
      event.preventDefault();
    });
  });
</script>
